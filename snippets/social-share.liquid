<div class="social-share">
  <span>{{ 'general.share' | t }}</span>
  <a href="https://www.facebook.com/sharer.php?u={{ shop.url }}{{ product.url }}" target="_blank" rel="noopener">Facebook</a>
  <a href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ product.url }}&text={{ product.title | url_param_escape }}" target="_blank" rel="noopener">X</a>
  <a href="https://pinterest.com/pin/create/button/?url={{ shop.url }}{{ product.url }}&media={{ product.featured_image | image_url: width: 800 }}&description={{ product.title | url_param_escape }}" target="_blank" rel="noopener">Pinterest</a>
  <button type="button" data-copy-link data-url="{{ shop.url }}{{ product.url }}">{{ 'general.copy_link' | t }}</button>
</div>
