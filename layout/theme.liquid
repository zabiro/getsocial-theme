{%- liquid
  assign custom_cursor_active = false
  if settings.enable_custom_cursor
    assign custom_cursor_active = true
    if settings.cursor_hide_on_product and template.name == 'product'
      assign custom_cursor_active = false
    endif
  endif
-%}
<!doctype html>
<html class="no-js{% if custom_cursor_active %} custom-cursor-active{% endif %}" lang="{{ request.locale.iso_code }}">
<head>
  <!-- GetSocial Theme | GetSocial | Luciano De Luque -->
  {%- render 'meta-tags' -%}
  <title>
    {{ page_title }}
    {%- unless page_title contains shop.name %} &ndash; {{ shop.name }}{% endunless -%}
  </title>
  {% if page_description %}
    <meta name="description" content="{{ page_description | escape }}">
  {% endif %}
  <link rel="canonical" href="{{ canonical_url }}">
  {%- if settings.favicon != blank -%}
    <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
  {%- endif -%}

  <link rel="preconnect" href="https://fonts.shopifycdn.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Poppins:wght@400;500;600;700&display=swap" rel="stylesheet">

  {{ content_for_header }}

  <style id="getsocial-theme-fonts">
    {%- render 'theme-fonts' -%}
  </style>
  {%- render 'css-variables' -%}
  {%- render 'custom-cursor-styles' -%}
  {%- render 'json-ld' -%}
  {%- render 'license-admin-notice' -%}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'theme-modern.css' | asset_url | stylesheet_tag }}
  {{ 'sunny-style.css' | asset_url | stylesheet_tag }}
  {{ 'sunny-interactions.css' | asset_url | stylesheet_tag }}
  {%- if settings.enable_custom_cursor -%}
    {{ 'custom-cursor.css' | asset_url | stylesheet_tag }}
  {%- endif -%}
  {%- if settings.custom_css != blank -%}<style>{{ settings.custom_css }}</style>{%- endif -%}
  {%- if settings.custom_head_scripts != blank -%}{{ settings.custom_head_scripts }}{%- endif -%}
  <script>document.documentElement.classList.replace('no-js','js');</script>
</head>
<body class="template-{{ template.name }} color-preset--{{ settings.color_preset | default: 'custom' }} header-style--{{ settings.header_style }} cart-type--{{ settings.cart_type }}{% if settings.enable_animations %} animations-enabled{% endif %}{% if settings.header_scroll_hide %} header-scroll-hide{% endif %}" data-shop-url="{{ shop.url }}">
  <a class="skip-link" href="#MainContent">{{ 'general.skip_to_content' | t }}</a>

  {% sections 'header-group' %}

  {%- if settings.show_breadcrumbs -%}
    {%- render 'breadcrumbs' -%}
  {%- endif -%}

  <main id="MainContent" class="main-content" role="main">
    {{ content_for_layout }}
  </main>

  {% sections 'footer-group' %}

  {%- if settings.cart_type == 'drawer' or settings.cart_type == 'notification' -%}
    {%- section 'cart-drawer' -%}
  {%- endif -%}

  {%- section 'search-modal' -%}
  {%- section 'newsletter-popup' -%}
  {%- section 'cookie-bar' -%}
  {%- section 'age-verifier' -%}

  {%- if settings.enable_quick_view -%}
    {% render 'quick-view-modal' %}
  {%- endif -%}
  {% render 'size-chart-modal' %}

  {%- if settings.back_to_top -%}
    <button type="button" class="back-to-top" data-back-to-top aria-label="{{ 'general.back_to_top' | t }}">↑</button>
  {%- endif -%}

  {% render 'whatsapp-float' %}

  {%- if settings.enable_compare -%}
    {% render 'compare-bar' %}
  {%- endif -%}

  <script>
    window.themeSettings = {
      cartType: {{ settings.cart_type | json }},
      freeShippingThreshold: {{ settings.cart_free_shipping_threshold | default: 0 | json }},
      predictiveSearch: {{ settings.predictive_search | json }},
      animations: {{ settings.enable_animations | json }},
      compareMax: {{ settings.compare_max | default: 4 | json }},
      headerScrollHide: {{ settings.header_scroll_hide | json }},
      customCursor: {
        enabled: {{ settings.enable_custom_cursor | json }},
        style: {{ settings.cursor_style | default: 'ring' | json }},
        imageUrl: {% if settings.cursor_image != blank %}{{ settings.cursor_image | image_url: width: 256 | json }}{% else %}null{% endif %},
        imageHoverUrl: {% if settings.cursor_image_hover != blank %}{{ settings.cursor_image_hover | image_url: width: 256 | json }}{% else %}null{% endif %},
        size: {{ settings.cursor_size | default: 28 | json }},
        sizeHover: {{ settings.cursor_size_hover | default: 44 | json }},
        smooth: {{ settings.cursor_smooth_follow | default: true | json }},
        hideOnProduct: {{ settings.cursor_hide_on_product | default: true | json }}
      }
    };
    window.themeStrings = {
      wishlistEmpty: {{ 'wishlist.empty' | t | json }},
      compareEmpty: {{ 'compare.empty' | t | json }},
      loading: {{ 'general.loading' | t | json }},
      addToCart: {{ 'products.product.add_to_cart' | t | json }},
      viewProduct: {{ 'products.view_product' | t | json }}
    };
  </script>
  <script src="{{ 'theme.js' | asset_url }}" defer></script>
  <script src="{{ 'product-carousel.js' | asset_url }}" defer></script>
  <script src="{{ 'collection-tabs.js' | asset_url }}" defer></script>
  {%- if settings.enable_custom_cursor -%}
    <script src="{{ 'custom-cursor.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if settings.color_preset == 'sunny' or settings.color_preset == 'beauty' -%}
    <script src="{{ 'sunny-interactions.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if template.name == 'collection' -%}
    <script src="{{ 'collection-ajax.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if template.name == 'product' -%}
    <script src="{{ 'product-gallery.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if settings.enable_wishlist or settings.enable_compare -%}
    <script src="{{ 'wishlist-compare.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if settings.enable_quick_view -%}
    <script src="{{ 'quick-view.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if settings.predictive_search -%}
    <script src="{{ 'predictive-search.js' | asset_url }}" defer></script>
  {%- endif -%}
  {%- if settings.enable_license_check -%}
    <script src="{{ 'license-check.js' | asset_url }}" defer></script>
  {%- endif -%}
</body>
</html>
