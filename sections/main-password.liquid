<section class="password-page section-spacing">
  <div class="page-width" style="max-width:420px;margin:0 auto;text-align:center">
    {%- if section.settings.logo != blank -%}
      {{ section.settings.logo | image_url: width: 200 | image_tag: style: 'margin:0 auto 2rem' }}
    {%- else -%}
      <h1>{{ shop.name }}</h1>
    {%- endif -%}
    <p>{{ 'password.message' | t }}</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <label for="Password" class="visually-hidden">{{ 'password.label' | t }}</label>
      <input type="password" name="password" id="Password" placeholder="{{ 'password.placeholder' | t }}" style="width:100%;margin:1rem 0;padding:.75rem">
      <button type="submit" class="button" style="width:100%">{{ 'password.submit' | t }}</button>
    {% endform %}
    <p style="margin-top:2rem;font-size:var(--font-size-small)">{{ 'password.admin' | t }} <a href="/admin">{{ 'password.admin_link' | t }}</a></p>
  </div>
</section>

{% schema %}
{
  "name": "Página de contraseña",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" }
  ]
}
{% endschema %}
