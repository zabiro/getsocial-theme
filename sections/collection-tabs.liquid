{%- comment -%}
  Colecciones con pestañas + grid o carrusel (columnas móvil/tablet/desktop configurables)
{%- endcomment -%}
{%- assign tab_blocks = section.blocks | where: 'type', 'tab' -%}

<section
  class="collection-tabs section-spacing"
  data-collection-tabs
  style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <header class="collection-tabs__header section-header">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="collection-tabs__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
      </header>
    {%- endif -%}

    {%- if tab_blocks.size > 0 -%}
      <div class="collection-tabs__nav" role="tablist" aria-label="{{ section.settings.heading | default: 'Colecciones' | escape }}">
        {%- for block in tab_blocks -%}
          {%- assign tab_collection = block.settings.collection -%}
          {%- assign tab_label = block.settings.label -%}
          {%- if tab_label == blank and tab_collection != blank -%}
            {%- assign tab_label = tab_collection.title -%}
          {%- endif -%}
          {%- if tab_label == blank -%}
            {%- assign tab_label = 'Colección' | append: ' ' | append: forloop.index -%}
          {%- endif -%}
          <button
            type="button"
            class="collection-tabs__tab{% if forloop.first %} is-active{% endif %}"
            role="tab"
            id="tab-{{ section.id }}-{{ forloop.index0 }}"
            aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
            aria-controls="panel-{{ section.id }}-{{ forloop.index0 }}"
            data-tab="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {{ tab_label }}
          </button>
        {%- endfor -%}
      </div>

      <div class="collection-tabs__panels">
        {%- for block in tab_blocks -%}
          <div
            id="panel-{{ section.id }}-{{ forloop.index0 }}"
            class="collection-tabs__panel{% unless forloop.first %} hidden{% endunless %}"
            role="tabpanel"
            aria-labelledby="tab-{{ section.id }}-{{ forloop.index0 }}"
            data-tab-panel="{{ forloop.index0 }}"
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.show_view_all and block.settings.collection != blank -%}
              <div class="collection-tabs__panel-head">
                <a href="{{ block.settings.collection.url }}" class="button button--secondary button--small">{{ 'general.view_all' | t }}</a>
              </div>
            {%- endif -%}
            {% render 'product-showcase',
              collection: block.settings.collection,
              product_list: block.settings.product_list,
              limit: section.settings.products_to_show,
              layout: section.settings.layout,
              columns_mobile: section.settings.columns_mobile,
              columns_tablet: section.settings.columns_tablet,
              columns_desktop: section.settings.columns_desktop,
              show_nav: section.settings.show_nav,
              unique_id: section.id | append: '-' | append: forloop.index0
            %}
          </div>
        {%- endfor -%}
      </div>
    {%- else -%}
      <p class="collection-tabs__empty">{{ 'sections.collection_tabs.empty' | t }}</p>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Colecciones con pestañas",
  "tag": "section",
  "class": "section-collection-tabs",
  "max_blocks": 8,
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Nuestros productos" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    { "type": "header", "content": "Disposición" },
    {
      "type": "select",
      "id": "layout",
      "label": "Modo de visualización",
      "options": [
        { "value": "carousel", "label": "Carrusel horizontal" },
        { "value": "grid", "label": "Grid (rejilla)" }
      ],
      "default": "carousel"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 24,
      "step": 1,
      "label": "Productos por pestaña",
      "default": 8
    },
    { "type": "checkbox", "id": "show_nav", "label": "Flechas del carrusel", "default": true, "info": "Solo aplica en modo carrusel" },
    { "type": "header", "content": "Columnas visibles" },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columnas en móvil",
      "default": 2,
      "info": "Cuántos productos se ven a la vez en pantallas pequeñas"
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columnas en tablet",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columnas en escritorio",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    { "type": "header", "content": "Espaciado" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen inferior",
      "default": 48
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Pestaña / colección",
      "settings": [
        { "type": "text", "id": "label", "label": "Nombre de la pestaña", "info": "Vacío = título de la colección" },
        { "type": "collection", "id": "collection", "label": "Colección" },
        { "type": "product_list", "id": "product_list", "label": "Productos manuales (opcional)" },
        { "type": "checkbox", "id": "show_view_all", "label": "Enlace ver todo", "default": true }
      ]
    }
  ],
  "presets": [
    {
      "name": "Colecciones con pestañas",
      "blocks": [
        { "type": "tab", "settings": { "label": "Todos" } },
        { "type": "tab", "settings": { "label": "Novedades" } },
        { "type": "tab", "settings": { "label": "Ofertas" } }
      ]
    }
  ]
}
{% endschema %}
