<script type="application/json" data-product-json>{{ product | json }}</script>

<section class="main-product section-spacing{% if settings.color_preset == 'sunny' or settings.color_preset == 'beauty' %} main-product--vibrant{% endif %}" data-product-section data-product-id="{{ product.id }}" data-product-handle="{{ product.handle }}">
  <div class="page-width product-main">
    <div class="product-gallery product-gallery--{{ settings.product_gallery_layout }}" data-product-gallery>
      {%- if settings.product_gallery_layout contains 'thumbnails' and product.media.size > 0 -%}
        {%- assign thumbs_vertical = false -%}
        {%- if settings.product_gallery_layout == 'thumbnails_left' -%}
          {%- assign thumbs_vertical = true -%}
        {%- endif -%}
        <div class="product-gallery__thumbs-carousel{% if thumbs_vertical %} product-gallery__thumbs-carousel--vertical{% else %} product-gallery__thumbs-carousel--horizontal{% endif %}" data-thumbs-carousel>
          <button type="button" class="product-gallery__arrow product-gallery__arrow--prev" data-thumbs-prev aria-label="{{ 'general.pagination.previous' | t }}">
            {%- if thumbs_vertical -%}{% render 'icon-chevron', direction: 'up' %}{%- else -%}{% render 'icon-chevron', direction: 'left' %}{%- endif -%}
          </button>
          <div class="product-gallery__thumbs-viewport" data-thumbs-viewport>
            <div class="product-gallery__thumbs-track" data-thumbs-track>
              {%- for media in product.media -%}
                <button type="button" class="product-gallery__thumb{% if forloop.first %} is-active{% endif %}" data-thumb="{{ forloop.index0 }}" data-media-id="{{ media.id }}" aria-label="{{ media.alt | default: product.title | escape }}">
                  {{ media.preview_image | image_url: width: 200 | image_tag: class: 'product-gallery__thumb-img', loading: 'lazy', widths: '76, 152', sizes: '76px' }}
                </button>
              {%- endfor -%}
            </div>
          </div>
          <button type="button" class="product-gallery__arrow product-gallery__arrow--next" data-thumbs-next aria-label="{{ 'general.pagination.next' | t }}">
            {%- if thumbs_vertical -%}{% render 'icon-chevron', direction: 'down' %}{%- else -%}{% render 'icon-chevron', direction: 'right' %}{%- endif -%}
          </button>
        </div>
      {%- endif -%}
      <div class="product-gallery__main{% if settings.product_enable_zoom %} product-gallery__main--zoom{% endif %}" data-gallery-main>
        {%- if product.media.size > 1 -%}
          <button type="button" class="product-gallery__arrow product-gallery__arrow--main product-gallery__arrow--main-prev" data-gallery-prev aria-label="{{ 'general.pagination.previous' | t }}">
            {% render 'icon-chevron', direction: 'left' %}
          </button>
          <button type="button" class="product-gallery__arrow product-gallery__arrow--main product-gallery__arrow--main-next" data-gallery-next aria-label="{{ 'general.pagination.next' | t }}">
            {% render 'icon-chevron', direction: 'right' %}
          </button>
        {%- endif -%}
        <div class="product-gallery__viewer">
          {%- for media in product.media -%}
            <div class="product-gallery__slide{% unless forloop.first %} hidden{% endunless %}" data-gallery-slide data-index="{{ forloop.index0 }}">
              {%- case media.media_type -%}
                {%- when 'image' -%}
                  <div class="product-gallery__media">
                    {%- assign gallery_img_class = 'product-gallery__image' -%}
                    {%- if forloop.first -%}
                      {{ media | image_url: width: 1400 | image_tag: loading: 'eager', id: 'ProductMainImage', class: gallery_img_class, alt: media.alt | default: product.title, widths: '400, 600, 800, 1000, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw' }}
                    {%- else -%}
                      {{ media | image_url: width: 1400 | image_tag: loading: 'lazy', class: gallery_img_class, alt: media.alt | default: product.title, widths: '400, 600, 800, 1000, 1200, 1400', sizes: '(min-width: 990px) 50vw, 100vw' }}
                    {%- endif -%}
                  </div>
                {%- when 'video' -%}
                  <div class="product-gallery__media product-gallery__media--video">
                    {{ media | video_tag: controls: true, class: 'product-gallery__video' }}
                  </div>
                {%- else -%}
                  <div class="product-gallery__media">
                    {{ media | image_url: width: 1400 | image_tag: class: 'product-gallery__image', alt: media.alt | default: product.title }}
                  </div>
              {%- endcase -%}
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>

    <div class="product-info" data-product-form>
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when '@app' -%}
            {% render block %}
        {%- endcase -%}
      {%- endfor -%}

      <div class="product-info__title-row">
        <h1>{{ product.title }}</h1>
        <div class="product-info__actions">
          {% render 'wishlist-button', product: product %}
          {% render 'compare-button', product: product %}
        </div>
      </div>
      {%- if settings.product_card_show_vendor -%}<p class="product-info__vendor">{{ product.vendor }}</p>{%- endif -%}
      <div class="product-info__price" data-product-price>{% render 'price', product: product %}</div>
      {% render 'inventory-urgency', product: product %}

      {%- if settings.product_show_sku -%}
        <p class="product-info__sku" data-product-sku><small>{{ 'products.product.sku' | t }}: <span>{{ product.selected_or_first_available_variant.sku }}</span></small></p>
      {%- endif -%}

      {%- if settings.product_show_inventory -%}
        <p class="product-info__stock" data-product-stock>
          {%- if product.selected_or_first_available_variant.available -%}
            <span style="color:var(--color-success)">{{ 'products.product.in_stock' | t }}</span>
          {%- else -%}
            <span style="color:var(--color-sale)">{{ 'products.product.out_of_stock' | t }}</span>
          {%- endif -%}
        </p>
      {%- endif -%}

      {%- form 'product', product, id: 'product-form', data-product-form-el: '' -%}
        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" data-variant-input>

        {%- comment -%} Swatches solo en tarjetas; en PDP un solo bloque por opción {%- endcomment -%}
        {%- unless product.has_only_default_variant -%}
          {%- for option in product.options_with_values -%}
            {%- assign option_down = option.name | downcase -%}
            {%- assign is_color_option = false -%}
            {%- if option_down contains 'color' or option_down contains 'colour' or option_down contains 'couleur' -%}
              {%- assign is_color_option = true -%}
            {%- endif -%}
            <fieldset class="product-option{% if is_color_option %} product-option--color{% endif %}" data-option-index="{{ forloop.index0 }}">
              <legend>{{ option.name }}</legend>
              <div class="product-option__values">
                {%- for value in option.values -%}
                  <label class="product-option__value">
                    <input type="radio" name="options[{{ option.name | escape }}]" value="{{ value | escape }}"{% if option.selected_value == value %} checked{% endif %}>
                    <span>{{ value }}</span>
                  </label>
                {%- endfor -%}
              </div>
            </fieldset>
          {%- endfor -%}
        {%- endunless -%}

        <div class="product-form__qty">
          <label for="Quantity">{{ 'products.product.quantity' | t }}</label>
          <button type="button" class="product-form__qty-btn" data-qty-minus aria-label="−">−</button>
          <input type="number" id="Quantity" name="quantity" value="1" min="1" data-qty-input>
          <button type="button" class="product-form__qty-btn" data-qty-plus aria-label="+">+</button>
        </div>

        <div class="product-form__actions">
          <button
            type="submit"
            name="add"
            class="button button--full button--atc"
            data-add-to-cart
            data-label-available="{{ 'products.product.add_to_cart' | t }}"
            data-label-sold="{{ 'products.product.sold_out' | t }}"
            {% unless product.selected_or_first_available_variant.available %} disabled{% endunless %}
          >
            {%- if product.selected_or_first_available_variant.available -%}
              {{ 'products.product.add_to_cart' | t }}
            {%- else -%}
              {{ 'products.product.sold_out' | t }}
            {%- endif -%}
          </button>
          <button
            type="button"
            class="button button--full button--buy-now"
            data-buy-now
            {% unless product.selected_or_first_available_variant.available %} disabled{% endunless %}
          >
            {{ 'products.product.buy_now' | t }}
          </button>
        </div>

        {%- if section.settings.show_dynamic_checkout -%}
          <div class="product-form__dynamic-checkout">
            {{ form | payment_button }}
          </div>
        {%- endif -%}
      {%- endform -%}

      {%- assign benefit_blocks = section.blocks | where: 'type', 'benefit' -%}
      {%- if benefit_blocks.size > 0 -%}
        <ul class="product-benefits">
          {%- for block in benefit_blocks -%}
            {%- if block.settings.text != blank -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- elsif settings.color_preset == 'sunny' or settings.color_preset == 'beauty' -%}
        {%- if product.description != blank -%}
          <div class="product-info__lead rte">{{ product.description }}</div>
        {%- endif -%}
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'trust' -%}
            <ul class="product-trust" {{ block.shopify_attributes }}>
              <li>{{ block.settings.icon }} {{ block.settings.text }}</li>
            </ul>
          {%- when 'size_chart' -%}
            {%- if block.settings.page != blank -%}
              <button type="button" class="size-chart-link" data-size-chart-open data-size-chart-target="size-chart-{{ block.id }}" {{ block.shopify_attributes }}>{{ block.settings.label }}</button>
              <div id="size-chart-{{ block.id }}" hidden class="rte size-chart-source">{{ block.settings.page.content }}</div>
            {%- endif -%}
        {%- endcase -%}
      {%- endfor -%}

      {%- if settings.product_show_share -%}
        {% render 'social-share', product: product %}
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <div class="product-tabs" data-product-tabs>
          {%- for block in section.blocks -%}
            {%- if block.type == 'tab' -%}
              <details class="product-tabs__item" {{ block.shopify_attributes }}{% if forloop.first %} open{% endif %}>
                <summary>{{ block.settings.title }}</summary>
                <div class="rte">{{ block.settings.content }}</div>
              </details>
            {%- endif -%}
          {%- endfor -%}
        </div>
      {%- elsif settings.product_tabs_count > 0 -%}
        <div class="product-tabs">
          <details open><summary>Descripción</summary><div class="rte">{{ product.description }}</div></details>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if settings.product_sticky_add_to_cart -%}
    <div class="sticky-atc" data-sticky-atc>
      <div class="page-width sticky-atc__inner">
        <span>{{ product.title }}</span>
        <span data-sticky-price>{% render 'price', product: product %}</span>
        <button type="submit" form="product-form" class="button button--small">{{ 'products.product.add_to_cart' | t }}</button>
      </div>
    </div>
  {%- endif -%}

  <div class="product-lightbox" data-product-lightbox hidden>
    <button type="button" class="product-lightbox__close" data-product-lightbox-close aria-label="{{ 'general.close' | t }}">×</button>
    <img src="" alt="" width="1200" height="1200" data-product-lightbox-img>
  </div>
</section>

{% schema %}
{
  "name": "Producto",
  "tag": "section",
  "class": "section-main-product",
  "settings": [
    { "type": "checkbox", "id": "show_dynamic_checkout", "label": "Botones de pago dinámico", "default": true }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Pestaña",
      "settings": [
        { "type": "text", "id": "title", "label": "Título", "default": "Detalles" },
        { "type": "richtext", "id": "content", "label": "Contenido" }
      ]
    },
    {
      "type": "benefit",
      "name": "Beneficio / bullet",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "Mejora textura, tono y luminosidad." }
      ]
    },
    {
      "type": "trust",
      "name": "Icono confianza",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji", "default": "🚚" },
        { "type": "text", "id": "text", "label": "Texto", "default": "Envío en 24-48h" }
      ]
    },
    {
      "type": "size_chart",
      "name": "Guía de tallas",
      "settings": [
        { "type": "text", "id": "label", "label": "Texto enlace", "default": "Guía de tallas" },
        { "type": "page", "id": "page", "label": "Página con tabla" }
      ]
    },
    { "type": "@app" }
  ],
  "default": {
    "blocks": [
      { "type": "benefit", "settings": { "text": "Despigmenta la piel y unifica el tono." } },
      { "type": "benefit", "settings": { "text": "Estimula la producción de colágeno." } },
      { "type": "benefit", "settings": { "text": "Rejuvenece la piel." } },
      { "type": "benefit", "settings": { "text": "Mejora textura, tono y luminosidad." } },
      { "type": "trust", "settings": { "icon": "🚚", "text": "Envío gratis +100€" } },
      { "type": "trust", "settings": { "icon": "↩️", "text": "Devolución 30 días" } },
      { "type": "tab", "settings": { "title": "Descripción", "content": "<p>Información del producto.</p>" } },
      { "type": "tab", "settings": { "title": "Envíos", "content": "<p>24-48h laborables.</p>" } }
    ]
  }
}
{% endschema %}
