<header class="site-header site-header--{{ settings.header_layout }}" role="banner" data-header data-site-header>
  <div class="page-width">
    <div class="site-header__inner">
      <button type="button" class="site-header__menu-toggle" aria-label="{{ 'general.menu' | t }}" data-mobile-menu-open>☰</button>

      <a href="{{ routes.root_url }}" class="site-header__logo">
        {%- if section.settings.logo != blank -%}
          {{ section.settings.logo | image_url: width: 240 | image_tag: alt: shop.name, loading: 'eager' }}
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>

      <nav class="site-header__nav" aria-label="Principal">
        {%- for link in section.settings.menu.links -%}
          <div class="site-header__nav-item{% if link.links.size > 0 %} has-dropdown{% endif %}">
            <a href="{{ link.url }}" class="{% if settings.color_preset == 'sunny' or settings.color_preset == 'beauty' %}link-hover-sunny{% endif %}">{{ link.title }}</a>
            {%- if link.links.size > 0 and section.settings.enable_mega_menu -%}
              <div class="site-header__dropdown mega-menu">
                {% render 'mega-menu', link: link, promo_image: section.settings.mega_menu_image, promo_link: section.settings.mega_menu_link, promo_title: section.settings.mega_menu_title %}
              </div>
            {%- elsif link.links.size > 0 -%}
              <ul class="site-header__dropdown">
                {%- for child in link.links -%}
                  <li><a href="{{ child.url }}">{{ child.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </nav>

      <div class="site-header__icons">
        {%- if settings.header_show_search -%}
          <button type="button" data-search-open aria-label="{{ 'general.search' | t }}">{% render 'icon-search' %}</button>
        {%- endif -%}
        {%- if settings.enable_wishlist -%}
          {%- assign wish_url = settings.wishlist_page.url | default: '/pages/wishlist' -%}
          <a href="{{ wish_url }}" class="site-header__wishlist" aria-label="{{ 'wishlist.title' | t }}">
            ♡<span class="site-header__count" data-wishlist-count>0</span>
          </a>
        {%- elsif settings.header_show_wishlist -%}
          <a href="{{ section.settings.wishlist_link | default: '#' }}" class="site-header__wishlist" aria-label="Wishlist">♡</a>
        {%- endif -%}
        {%- if settings.enable_compare -%}
          {%- assign cmp_url = settings.compare_page.url | default: '/pages/comparar' -%}
          <a href="{{ cmp_url }}" class="site-header__compare" aria-label="{{ 'compare.title' | t }}">
            ⇄<span class="site-header__count" data-compare-count>0</span>
          </a>
        {%- endif -%}
        {%- if settings.header_show_account -%}
          <a href="{{ routes.account_url }}" aria-label="{{ 'general.account' | t }}">👤</a>
        {%- endif -%}
        <a href="{{ routes.cart_url }}" class="site-header__cart" data-cart-open aria-label="{{ 'general.cart' | t }}">
          {% render 'icon-cart' %}
          <span class="site-header__count" data-cart-count>{{ cart.item_count }}</span>
        </a>
      </div>
    </div>
  </div>
</header>

{% render 'mobile-menu', menu: section.settings.menu %}

{% schema %}
{
  "name": "Cabecera",
  "class": "section-header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "link_list", "id": "menu", "label": "Menú principal", "default": "main-menu" },
    { "type": "checkbox", "id": "enable_mega_menu", "label": "Activar mega menú", "default": true },
    { "type": "image_picker", "id": "mega_menu_image", "label": "Imagen promo mega menú" },
    { "type": "text", "id": "mega_menu_title", "label": "Título promo" },
    { "type": "url", "id": "mega_menu_link", "label": "Enlace promo" },
    { "type": "url", "id": "wishlist_link", "label": "Enlace wishlist (app o página)" }
  ]
}
{% endschema %}
