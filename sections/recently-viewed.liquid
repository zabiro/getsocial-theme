<section class="recently-viewed section-spacing" data-recently-viewed data-limit="{{ section.settings.products_to_show }}" hidden>
  <div class="page-width">
    <h2>{{ section.settings.heading | default: 'Vistos recientemente' }}</h2>
    <div class="grid grid--4" data-recently-viewed-grid></div>
  </div>
</section>

{% schema %}
{
  "name": "Vistos recientemente",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Vistos recientemente" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 8, "step": 1, "label": "Productos", "default": 4 }
  ],
  "presets": [{ "name": "Vistos recientemente" }]
}
{% endschema %}
