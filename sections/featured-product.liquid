<section class="featured-product section-spacing">
  <div class="page-width">
    <div class="featured-product__grid">
      <div class="featured-product__media">
        {%- assign fp = section.settings.product -%}
        {%- if fp != blank and fp.featured_media -%}
          {{ fp.featured_media | image_url: width: 900 | image_tag: loading: 'lazy' }}
        {%- else -%}
          {% render 'section-placeholder', placeholder_type: 'product', class: 'section-placeholder', width: 900, height: 1100, alt: section.settings.heading %}
        {%- endif -%}
      </div>
      <div class="featured-product__info">
        {%- if section.settings.heading != blank -%}<p class="featured-product__label">{{ section.settings.heading }}</p>{%- endif -%}
        {%- if fp != blank -%}
          <h2><a href="{{ fp.url }}">{{ fp.title }}</a></h2>
          {% render 'price', product: fp %}
          {%- if section.settings.description != blank -%}
            <div class="rte" style="margin:1rem 0">{{ section.settings.description }}</div>
          {%- elsif fp.description != blank -%}
            <div class="rte" style="margin:1rem 0">{{ fp.description | strip_html | truncate: 280 }}</div>
          {%- endif -%}
          {%- if section.blocks.size > 0 -%}
            <ul class="featured-product__benefits">
              {%- for block in section.blocks -%}
                {%- if block.settings.text != blank -%}
                  <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
                {%- endif -%}
              {%- endfor -%}
            </ul>
          {%- endif -%}
          {%- form 'product', fp -%}
            <input type="hidden" name="id" value="{{ fp.selected_or_first_available_variant.id }}">
            <button type="submit" class="button"{% unless fp.available %} disabled{% endunless %}>
              {%- if fp.available -%}
                {{ section.settings.button_label | default: 'products.product.add_to_cart' | t }}
              {%- else -%}
                {{ settings.product_badge_soldout_text | default: 'Agotado' }}
              {%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <h2>{{ 'products.product.title' | t | default: 'Producto destacado' }}</h2>
          <p style="color:var(--color-text-light)">{{ 'sections.featured_product.no_product' | t | default: 'Selecciona un producto en la configuración de la sección.' }}</p>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Producto destacado",
  "settings": [
    { "type": "text", "id": "heading", "label": "Etiqueta superior", "default": "Destacado" },
    { "type": "product", "id": "product", "label": "Producto" },
    { "type": "richtext", "id": "description", "label": "Descripción (opcional, sustituye la del producto)" },
    { "type": "text", "id": "button_label", "label": "Texto botón comprar" }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Beneficio",
      "settings": [
        { "type": "text", "id": "text", "label": "Texto", "default": "Mejora textura, tono y luminosidad." }
      ]
    }
  ],
  "presets": [
    {
      "name": "Producto destacado",
      "blocks": [
        { "type": "benefit", "settings": { "text": "Despigmenta la piel y unifica el tono." } },
        { "type": "benefit", "settings": { "text": "Estimula la producción de colágeno." } },
        { "type": "benefit", "settings": { "text": "Rejuvenece la piel." } },
        { "type": "benefit", "settings": { "text": "Mejora textura, tono y luminosidad." } }
      ]
    }
  ]
}
{% endschema %}
