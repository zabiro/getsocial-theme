<section class="gallery section-spacing">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="gallery__grid gallery__grid--{{ section.settings.columns }}" data-gallery>
      {%- for block in section.blocks -%}
        <button type="button" class="gallery__item" data-gallery-item data-index="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
        </button>
      {%- endfor -%}
    </div>
  </div>
  <div class="gallery-lightbox" data-gallery-lightbox hidden>
    <button type="button" data-gallery-close>✕</button>
    <img src="" alt="" data-gallery-lightbox-img width="1200" height="1200">
  </div>
</section>

{% schema %}
{
  "name": "Galería de imágenes",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título" },
    { "type": "select", "id": "columns", "label": "Columnas", "options": [
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" },
      { "value": "5", "label": "5" }
    ], "default": "4" }
  ],
  "blocks": [
    { "type": "image", "name": "Imagen", "settings": [{ "type": "image_picker", "id": "image", "label": "Imagen" }] }
  ],
  "presets": [{ "name": "Galería", "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }] }]
}
{% endschema %}
