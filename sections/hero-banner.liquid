{%- liquid
  assign min_h = section.settings.min_height
  assign overlay = section.settings.overlay_opacity | divided_by: 100.0
-%}
<section
  class="hero section-spacing fade-in"
  style="--hero-min-height:{{ min_h }}vh;--hero-overlay:rgba(0,0,0,{{ overlay }});--hero-text:{{ section.settings.text_color }}"
>
  <div class="hero__media">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
    {%- elsif section.settings.image != blank -%}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', sizes: '100vw' }}
    {%- else -%}
      {% render 'section-placeholder', placeholder_type: 'hero', class: 'hero__image section-placeholder', loading: 'eager', width: 2000, height: 1100, alt: section.settings.heading %}
    {%- endif -%}
  </div>
  <div class="hero__overlay"></div>
  <div class="page-width hero__content hero__content--{{ section.settings.content_alignment }}">
    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.heading != blank -%}
      <h1>{{ section.settings.heading }}</h1>
    {%- endif -%}
    {%- if section.settings.description != blank -%}
      <p>{{ section.settings.description }}</p>
    {%- endif -%}
    <div class="hero__buttons hero__buttons--{{ section.settings.content_alignment }}">
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button">{{ section.settings.button_label }}</a>
      {%- endif -%}
      {%- if section.settings.button_label_2 != blank -%}
        <a href="{{ section.settings.button_link_2 }}" class="button button--secondary">{{ section.settings.button_label_2 }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagen de fondo" },
    { "type": "video", "id": "video", "label": "Video de fondo (opcional)" },
    { "type": "range", "id": "min_height", "min": 40, "max": 100, "step": 5, "unit": "vh", "label": "Altura mínima", "default": 70 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "unit": "%", "label": "Opacidad overlay", "default": 35 },
    { "type": "color", "id": "text_color", "label": "Color texto", "default": "#ffffff" },
    { "type": "text", "id": "subheading", "label": "Subtítulo", "default": "Nueva colección" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Descubre tu estilo" },
    { "type": "textarea", "id": "description", "label": "Descripción" },
    { "type": "select", "id": "content_alignment", "label": "Alineación", "options": [
      { "value": "left", "label": "Izquierda" },
      { "value": "center", "label": "Centro" },
      { "value": "right", "label": "Derecha" }
    ], "default": "center" },
    { "type": "text", "id": "button_label", "label": "Botón 1", "default": "Comprar ahora" },
    { "type": "url", "id": "button_link", "label": "Enlace botón 1" },
    { "type": "text", "id": "button_label_2", "label": "Botón 2" },
    { "type": "url", "id": "button_link_2", "label": "Enlace botón 2" }
  ],
  "presets": [{ "name": "Hero banner" }]
}
{% endschema %}
