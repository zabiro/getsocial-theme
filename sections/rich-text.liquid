<section class="rich-text section-spacing" style="background:{{ section.settings.background }};text-align:{{ section.settings.alignment }}">
  <div class="page-width" style="max-width:{{ section.settings.content_width }}px;margin:0 auto">
    {%- for block in section.blocks -%}
      <div {{ block.shopify_attributes }}>
        {%- case block.type -%}
          {%- when 'heading' -%}
            <{{ block.settings.heading_tag }}>{{ block.settings.heading }}</{{ block.settings.heading_tag }}>
          {%- when 'text' -%}
            <div class="rte">{{ block.settings.text }}</div>
          {%- when 'button' -%}
            <a href="{{ block.settings.link }}" class="button{% if block.settings.style == 'secondary' %} button--secondary{% endif %}">{{ block.settings.label }}</a>
        {%- endcase -%}
      </div>
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Texto enriquecido",
  "settings": [
    { "type": "color", "id": "background", "label": "Fondo", "default": "transparent" },
    { "type": "select", "id": "alignment", "label": "Alineación", "options": [
      { "value": "left", "label": "Izquierda" },
      { "value": "center", "label": "Centro" }
    ], "default": "center" },
    { "type": "range", "id": "content_width", "min": 400, "max": 1000, "step": 50, "unit": "px", "label": "Ancho contenido", "default": 700 }
  ],
  "blocks": [
    {
      "type": "heading",
      "name": "Título",
      "settings": [
        { "type": "text", "id": "heading", "label": "Texto", "default": "Título de sección" },
        { "type": "select", "id": "heading_tag", "label": "Etiqueta HTML", "options": [
          { "value": "h2", "label": "H2" },
          { "value": "h3", "label": "H3" }
        ], "default": "h2" }
      ]
    },
    { "type": "text", "name": "Texto", "settings": [{ "type": "richtext", "id": "text", "label": "Contenido" }] },
    {
      "type": "button",
      "name": "Botón",
      "settings": [
        { "type": "text", "id": "label", "label": "Texto", "default": "Saber más" },
        { "type": "url", "id": "link", "label": "Enlace" },
        { "type": "select", "id": "style", "label": "Estilo", "options": [
          { "value": "primary", "label": "Primario" },
          { "value": "secondary", "label": "Secundario" }
        ], "default": "primary" }
      ]
    }
  ],
  "presets": [{ "name": "Texto enriquecido", "blocks": [{ "type": "heading" }, { "type": "text" }] }]
}
{% endschema %}
