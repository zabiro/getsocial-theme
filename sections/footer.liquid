<footer class="site-footer" role="contentinfo">
  <div class="page-width">
    <div class="site-footer__grid">
      {%- for block in section.blocks -%}
        <div class="site-footer__column" {{ block.shopify_attributes }}>
          {%- case block.type -%}
            {%- when 'text' -%}
              {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
              {%- if block.settings.text != blank -%}<div class="rte">{{ block.settings.text }}</div>{%- endif -%}
            {%- when 'menu' -%}
              {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
              <ul>
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- when 'newsletter' -%}
              <h3>{{ block.settings.heading | default: 'Newsletter' }}</h3>
              {% form 'customer', class: 'footer-newsletter' %}
                <input type="email" name="contact[email]" placeholder="{{ block.settings.placeholder }}" required>
                <button type="submit" class="button button--small">{{ block.settings.button_label }}</button>
              {% endform %}
          {%- endcase -%}
        </div>
      {%- endfor -%}
    </div>
    {%- if section.settings.show_payment_icons -%}
      <div class="site-footer__payment">{% render 'payment-icons' %}</div>
    {%- endif -%}
    {%- if section.settings.show_social -%}
      <div class="site-footer__social">
        {%- if settings.social_instagram != blank -%}<a href="{{ settings.social_instagram }}" rel="noopener">Instagram</a>{%- endif -%}
        {%- if settings.social_facebook != blank -%}<a href="{{ settings.social_facebook }}" rel="noopener">Facebook</a>{%- endif -%}
        {%- if settings.social_tiktok != blank -%}<a href="{{ settings.social_tiktok }}" rel="noopener">TikTok</a>{%- endif -%}
        {%- if settings.social_youtube != blank -%}<a href="{{ settings.social_youtube }}" rel="noopener">YouTube</a>{%- endif -%}
      </div>
    {%- endif -%}
    <p class="site-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}{% if section.settings.show_powered_by %} · {{ powered_by_link }}{% endif %}</p>
  </div>
</footer>
<style>.site-footer__social{display:flex;gap:1rem;flex-wrap:wrap;margin:1.5rem 0;font-size:var(--font-size-small)}</style>

{% schema %}
{
  "name": "Pie de página",
  "settings": [
    { "type": "checkbox", "id": "show_payment_icons", "label": "Iconos de pago", "default": true },
    { "type": "checkbox", "id": "show_social", "label": "Mostrar redes (desde configuración tema)", "default": true },
    { "type": "checkbox", "id": "show_powered_by", "label": "Mostrar Powered by Shopify", "default": false }
  ],
  "max_blocks": 6,
  "blocks": [
    {
      "type": "text",
      "name": "Texto",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título" },
        { "type": "richtext", "id": "text", "label": "Contenido" }
      ]
    },
    {
      "type": "menu",
      "name": "Menú",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título" },
        { "type": "link_list", "id": "menu", "label": "Menú" }
      ]
    },
    {
      "type": "newsletter",
      "name": "Newsletter",
      "settings": [
        { "type": "text", "id": "heading", "label": "Título", "default": "Suscríbete" },
        { "type": "text", "id": "placeholder", "label": "Placeholder email", "default": "tu@email.com" },
        { "type": "text", "id": "button_label", "label": "Texto botón", "default": "Enviar" }
      ]
    }
  ],
  "default": {
    "blocks": [
      { "type": "text" },
      { "type": "menu" },
      { "type": "newsletter" }
    ]
  }
}
{% endschema %}
