<section class="countdown section-spacing" style="background:{{ section.settings.background }};color:{{ section.settings.text_color }}">
  <div class="page-width countdown__inner" data-countdown data-end="{{ section.settings.end_date }}">
    {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
    {%- if section.settings.subheading != blank -%}<p>{{ section.settings.subheading }}</p>{%- endif -%}
    <div class="countdown__timer">
      <div><span data-days>00</span><small>{{ 'sections.countdown.days' | t }}</small></div>
      <div><span data-hours>00</span><small>{{ 'sections.countdown.hours' | t }}</small></div>
      <div><span data-minutes>00</span><small>{{ 'sections.countdown.minutes' | t }}</small></div>
      <div><span data-seconds>00</span><small>{{ 'sections.countdown.seconds' | t }}</small></div>
    </div>
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_link }}" class="button">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Cuenta atrás",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Oferta por tiempo limitado" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    { "type": "text", "id": "end_date", "label": "Fecha fin (YYYY-MM-DD HH:MM)", "default": "2026-12-31 23:59", "info": "Formato: 2026-12-31 23:59" },
    { "type": "text", "id": "button_label", "label": "Botón", "default": "Comprar ahora" },
    { "type": "url", "id": "button_link", "label": "Enlace" },
    { "type": "color", "id": "background", "label": "Fondo", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#ffffff" }
  ],
  "presets": [{ "name": "Cuenta atrás" }]
}
{% endschema %}
