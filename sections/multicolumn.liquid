<section class="multicolumn section-spacing" style="background:{{ section.settings.background_color }}">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 style="text-align:{{ section.settings.heading_alignment }};margin-bottom:2rem">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="grid grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        <div class="multicolumn__item" {{ block.shopify_attributes }} style="text-align:{{ block.settings.text_alignment }}">
          {%- if block.settings.icon_image != blank -%}
            {{ block.settings.icon_image | image_url: width: 80 | image_tag }}
          {%- elsif block.settings.icon != blank -%}
            <div style="font-size:2rem">{{ block.settings.icon }}</div>
          {%- endif -%}
          {%- if block.settings.heading != blank -%}<h3>{{ block.settings.heading }}</h3>{%- endif -%}
          {%- if block.settings.text != blank -%}<p>{{ block.settings.text }}</p>{%- endif -%}
          {%- if block.settings.link_label != blank -%}
            <a href="{{ block.settings.link }}">{{ block.settings.link_label }} →</a>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Multicolumna",
  "max_blocks": 6,
  "settings": [
    { "type": "text", "id": "heading", "label": "Título de sección" },
    { "type": "select", "id": "heading_alignment", "label": "Alineación título", "options": [
      { "value": "left", "label": "Izquierda" },
      { "value": "center", "label": "Centro" }
    ], "default": "center" },
    { "type": "select", "id": "columns", "label": "Columnas", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "3" },
    { "type": "color", "id": "background_color", "label": "Fondo", "default": "transparent" }
  ],
  "blocks": [
    {
      "type": "column",
      "name": "Columna",
      "settings": [
        { "type": "text", "id": "icon", "label": "Emoji / icono texto" },
        { "type": "image_picker", "id": "icon_image", "label": "Icono imagen" },
        { "type": "text", "id": "heading", "label": "Título", "default": "Envío rápido" },
        { "type": "textarea", "id": "text", "label": "Texto", "default": "Entrega en 24-48h" },
        { "type": "text", "id": "link_label", "label": "Texto enlace" },
        { "type": "url", "id": "link", "label": "Enlace" },
        { "type": "select", "id": "text_alignment", "label": "Alineación", "options": [
          { "value": "left", "label": "Izquierda" },
          { "value": "center", "label": "Centro" }
        ], "default": "center" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Multicolumna",
      "blocks": [
        { "type": "column", "settings": { "icon": "🚚", "heading": "Envío gratis", "text": "En pedidos +100€" } },
        { "type": "column", "settings": { "icon": "↩️", "heading": "Devoluciones", "text": "30 días sin complicaciones" } },
        { "type": "column", "settings": { "icon": "💬", "heading": "Soporte", "text": "Atención personalizada" } }
      ]
    }
  ]
}
{% endschema %}
