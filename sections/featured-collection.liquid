<section class="featured-collection section-spacing fade-in">
  <div class="page-width">
    <div class="section-header" style="display:flex;justify-content:space-between;align-items:end;margin-bottom:2rem;flex-wrap:wrap;gap:1rem">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.show_view_all and section.settings.collection != blank -%}
        <a href="{{ section.settings.collection.url }}" class="button button--secondary">{{ 'general.view_all' | t }}</a>
      {%- endif -%}
    </div>
    <div class="grid grid--{{ section.settings.columns_desktop }}">
      {%- assign collection = section.settings.collection -%}
      {%- if collection != blank -%}
        {%- for product in collection.products limit: section.settings.products_to_show -%}
          {% render 'card-product', product: product, card_index: forloop.index %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..section.settings.products_to_show) -%}
          <article class="product-card">
            <div class="product-card__media ratio-portrait">
              <img src="{{ 'placeholder-product-' | append: i | append: '.svg' | asset_url }}" alt="" class="product-card__image product-card__placeholder" loading="lazy" width="600" height="800">
            </div>
            <div class="product-card__info"><h3>Producto ejemplo {{ i }}</h3></div>
          </article>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Colección destacada",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Productos destacados" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 24, "step": 1, "label": "Productos a mostrar", "default": 8 },
    { "type": "select", "id": "columns_desktop", "label": "Columnas (escritorio)", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "4" },
    { "type": "checkbox", "id": "show_view_all", "label": "Mostrar enlace ver todo", "default": true }
  ],
  "presets": [{ "name": "Colección destacada" }]
}
{% endschema %}
