<div class="cart-drawer" data-cart-drawer aria-hidden="true">
  <div class="cart-drawer__overlay" data-cart-close></div>
  <div class="cart-drawer__panel" role="dialog" aria-label="{{ 'cart.title' | t }}">
    <div class="cart-drawer__head">
      <h2>{{ 'cart.title' | t }}</h2>
      <button type="button" data-cart-close aria-label="{{ 'general.close' | t }}">✕</button>
    </div>

    {%- if settings.cart_show_shipping_bar and settings.cart_free_shipping_threshold != blank -%}
      {%- assign threshold = settings.cart_free_shipping_threshold | times: 100 -%}
      {%- assign remaining = threshold | minus: cart.total_price -%}
      <div class="cart-drawer__shipping">
        {%- if remaining > 0 -%}
          <p>{{ 'cart.free_shipping_remaining' | t: amount: remaining | money }}</p>
          {%- assign progress = cart.total_price | times: 100 | divided_by: threshold -%}
          <div class="shipping-bar"><div class="shipping-bar__fill" style="width:{{ progress | at_most: 100 }}%"></div></div>
        {%- else -%}
          <p>{{ 'cart.free_shipping_achieved' | t }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="cart-drawer__items">
      {%- if cart.item_count > 0 -%}
        {%- for item in cart.items -%}
          <div class="cart-drawer__line">
            {%- if item.image -%}{{ item.image | image_url: width: 100 | image_tag }}{%- endif -%}
            <div>
              <a href="{{ item.url }}"><strong>{{ item.product.title }}</strong></a>
              <p>{{ item.final_line_price | money }} × {{ item.quantity }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        <p>{{ settings.cart_empty_message | default: 'cart.empty' | t }}</p>
        {%- if settings.cart_empty_collection != blank -%}
          <a href="{{ settings.cart_empty_collection.url }}" class="button">{{ 'general.continue_shopping' | t }}</a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if settings.cart_upsell_collection != blank and cart.item_count > 0 -%}
      <div class="cart-drawer__upsell">
        <p class="cart-drawer__upsell-title">{{ settings.cart_upsell_heading | default: 'También te puede interesar' }}</p>
        <div class="cart-drawer__upsell-grid">
          {%- for product in settings.cart_upsell_collection.products limit: settings.cart_upsell_limit -%}
            <a href="{{ product.url }}" class="cart-drawer__upsell-item">
              {{ product.featured_image | image_url: width: 120 | image_tag: loading: 'lazy' }}
              <span>{{ product.title | truncate: 28 }}</span>
              <span>{{ product.price | money }}</span>
            </a>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

    {%- if cart.item_count > 0 -%}
      <div class="cart-drawer__footer">
        <p class="cart-drawer__subtotal"><span>{{ 'general.subtotal' | t }}</span><span>{{ cart.total_price | money }}</span></p>
        {% render 'payment-icons' %}
        <a href="{{ routes.cart_url }}" class="button button--secondary button--full">{{ 'general.cart' | t }}</a>
        <a href="{{ routes.checkout_url }}" class="button button--full">{{ 'general.checkout' | t }}</a>
      </div>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "Cajón del carrito",
  "settings": []
}
{% endschema %}
