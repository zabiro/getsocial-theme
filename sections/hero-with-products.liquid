{%- comment -%}
  Hero + carrusel de productos (estructura home tipo Sunny Hunny)
{%- endcomment -%}
{%- liquid
  assign collection = section.settings.collection
  assign product_limit = section.settings.products_to_show
  assign overlay = section.settings.overlay_opacity | divided_by: 100.0
-%}
<section
  class="hero-with-products section-spacing"
  style="--hero-overlay:rgba(0,0,0,{{ overlay }});--hero-text:{{ section.settings.text_color }};--hero-min-h:{{ section.settings.min_height }}vh"
  data-hero-with-products
>
  <div class="hero-with-products__hero hero hero--tropical">
    <div class="hero__media">
      {%- if section.settings.video != blank -%}
        {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true }}
      {%- elsif section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 2400 | image_tag: loading: 'eager', sizes: '100vw', class: 'hero__image' }}
      {%- else -%}
        {% render 'section-placeholder', placeholder_type: 'hero', class: 'hero__image section-placeholder', loading: 'eager', width: 2000, height: 1100, alt: section.settings.heading %}
      {%- endif -%}
    </div>
    <div class="hero__overlay"></div>
    <div class="page-width hero-with-products__content hero__content hero__content--center">
      {%- if section.settings.logo != blank -%}
        <div class="hero-with-products__logo">
          {{ section.settings.logo | image_url: width: 450 | image_tag: loading: 'eager', alt: shop.name, class: 'hero-with-products__logo-img' }}
        </div>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h1>{{ section.settings.heading }}</h1>
      {%- endif -%}
      {%- if section.settings.description != blank -%}
        <p>{{ section.settings.description }}</p>
      {%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <div class="hero__buttons hero__buttons--center">
          <a href="{{ section.settings.button_link | default: routes.all_products_collection_url }}" class="button">
            {{ section.settings.button_label }}
          </a>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_product_carousel -%}
    <div class="hero-with-products__carousel-wrap page-width">
      {% render 'product-showcase',
        collection: collection,
        limit: product_limit,
        layout: 'carousel',
        columns_mobile: section.settings.columns_mobile,
        columns_tablet: section.settings.columns_tablet,
        columns_desktop: section.settings.columns_desktop,
        show_nav: section.settings.show_carousel_nav,
        unique_id: section.id | append: '-hero'
      %}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Hero con productos",
  "tag": "section",
  "settings": [
    { "type": "header", "content": "Fondo del hero" },
    { "type": "image_picker", "id": "image", "label": "Imagen de fondo" },
    { "type": "video", "id": "video", "label": "Video de fondo (prioridad sobre imagen)" },
    { "type": "range", "id": "min_height", "min": 50, "max": 95, "step": 5, "unit": "vh", "label": "Altura hero", "default": 80 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 70, "step": 5, "unit": "%", "label": "Overlay", "default": 30 },
    { "type": "color", "id": "text_color", "label": "Color texto", "default": "#ffffff" },
    { "type": "image_picker", "id": "logo", "label": "Logo sobre el hero (opcional)" },
    { "type": "text", "id": "heading", "label": "Título", "default": "¡Paraíso para tu piel!" },
    { "type": "textarea", "id": "description", "label": "Descripción", "default": "Texturas tropicales. Aromas irresistibles. Piel de verano eterno." },
    { "type": "text", "id": "button_label", "label": "Texto botón" },
    { "type": "url", "id": "button_link", "label": "Enlace botón" },
    { "type": "header", "content": "Carrusel de productos (debajo del hero)" },
    { "type": "checkbox", "id": "show_product_carousel", "label": "Mostrar carrusel de productos", "default": true },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 12, "step": 1, "label": "Productos en carrusel", "default": 5 },
    { "type": "checkbox", "id": "show_carousel_nav", "label": "Flechas anterior/siguiente", "default": true },
    { "type": "header", "content": "Columnas del carrusel" },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columnas móvil",
      "default": 2
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columnas tablet",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columnas escritorio",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "5"
    }
  ],
  "presets": [
    {
      "name": "Hero con productos",
      "settings": {
        "heading": "¡Paraíso para tu piel!",
        "description": "Texturas tropicales. Aromas irresistibles. Piel de verano eterno.",
        "show_product_carousel": true,
        "products_to_show": 5
      }
    }
  ]
}
{% endschema %}
