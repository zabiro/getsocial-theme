{%- if section.settings.enable -%}
  <div class="announcement-bar" style="background:{{ section.settings.background }};color:{{ section.settings.text_color }}">
    <div class="page-width announcement-bar__inner">
      {%- if section.settings.link != blank -%}
        <a href="{{ section.settings.link }}">{{ section.settings.text }}</a>
      {%- else -%}
        <p>{{ section.settings.text }}</p>
      {%- endif -%}
    </div>
  </div>
{%- endif -%}

<style>
  .announcement-bar { text-align: center; padding: .5rem 0; font-size: var(--font-size-small); }
  .announcement-bar p { margin: 0; }
</style>

{% schema %}
{
  "name": "Barra de anuncios",
  "settings": [
    { "type": "checkbox", "id": "enable", "label": "Activar", "default": true },
    { "type": "text", "id": "text", "label": "Texto", "default": "Envío gratis en pedidos superiores a 100€" },
    { "type": "url", "id": "link", "label": "Enlace" },
    { "type": "color", "id": "background", "label": "Fondo", "default": "#1a1a1a" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#ffffff" }
  ]
}
{% endschema %}
