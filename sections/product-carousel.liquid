{%- comment -%}
  Carrusel / grid de productos — columnas móvil configurables
{%- endcomment -%}
<section
  class="product-carousel-section section-spacing"
  data-section-type="product-carousel"
  style="--section-pt: {{ section.settings.padding_top }}px; --section-pb: {{ section.settings.padding_bottom }}px;"
>
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <header class="product-carousel-section__header">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="product-carousel-section__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.show_view_all and section.settings.collection != blank -%}
          <a href="{{ section.settings.collection.url }}" class="button button--secondary button--small">{{ 'general.view_all' | t }}</a>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="product-carousel-section__inner{% if section.settings.layout == 'carousel' %} product-carousel-section__inner--carousel{% endif %}">
      {% render 'product-showcase',
        collection: section.settings.collection,
        product_list: section.settings.product_list,
        limit: section.settings.products_to_show,
        layout: section.settings.layout,
        columns_mobile: section.settings.columns_mobile,
        columns_tablet: section.settings.columns_tablet,
        columns_desktop: section.settings.columns_desktop,
        show_nav: section.settings.show_nav,
        unique_id: section.id
      %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Carrusel de productos",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Productos destacados" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "product_list", "id": "product_list", "label": "Productos manuales (si no hay colección)" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 16, "step": 1, "label": "Cantidad", "default": 5 },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposición",
      "options": [
        { "value": "carousel", "label": "Carrusel horizontal (Sunny)" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "carousel"
    },
    { "type": "checkbox", "id": "show_nav", "label": "Flechas navegación", "default": true },
    { "type": "header", "content": "Columnas visibles" },
    {
      "type": "range",
      "id": "columns_mobile",
      "min": 1,
      "max": 3,
      "step": 1,
      "label": "Columnas en móvil",
      "default": 2,
      "info": "Productos visibles a la vez en el carrusel (móvil)"
    },
    {
      "type": "range",
      "id": "columns_tablet",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columnas en tablet",
      "default": 2
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columnas en escritorio",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "show_view_all", "label": "Enlace ver todo", "default": false },
    { "type": "header", "content": "Espaciado" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen superior",
      "default": 48
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margen inferior",
      "default": 48
    }
  ],
  "presets": [
    {
      "name": "Carrusel de productos",
      "settings": {
        "heading": "El match perfecto para tu rutina",
        "layout": "carousel",
        "products_to_show": 5,
        "columns_mobile": 2,
        "columns_tablet": 2,
        "columns_desktop": "4"
      }
    }
  ]
}
{% endschema %}
