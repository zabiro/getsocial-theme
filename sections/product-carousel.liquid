{%- comment -%}
  Carrusel horizontal de productos — home, PDP «match perfecto», etc.
{%- endcomment -%}
{%- liquid
  assign collection = section.settings.collection
  assign limit = section.settings.products_to_show
-%}
<section class="product-carousel-section section-spacing" data-section-type="product-carousel">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <header class="product-carousel-section__header">
        <h2>{{ section.settings.heading }}</h2>
        {%- if section.settings.subheading != blank -%}
          <p class="product-carousel-section__sub">{{ section.settings.subheading }}</p>
        {%- endif -%}
        {%- if section.settings.show_view_all and collection != blank -%}
          <a href="{{ collection.url }}" class="button button--secondary button--small">{{ 'general.view_all' | t }}</a>
        {%- endif -%}
      </header>
    {%- endif -%}

    <div class="product-carousel{% if section.settings.layout == 'grid' %} product-carousel--grid{% endif %}" data-product-carousel>
      <div class="product-carousel__track{% if section.settings.layout == 'grid' %} grid grid--{{ section.settings.columns_desktop }}{% endif %}" data-carousel-track>
        {%- if collection != blank and collection.products_count > 0 -%}
          {%- for product in collection.products limit: limit -%}
            <div class="product-carousel__slide">
              {% render 'product-card', product: product, card_index: forloop.index %}
            </div>
          {%- endfor -%}
        {%- elsif section.settings.product_list != blank -%}
          {%- for product in section.settings.product_list limit: limit -%}
            <div class="product-carousel__slide">
              {% render 'product-card', product: product, card_index: forloop.index %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..limit) -%}
            <div class="product-carousel__slide">
              <article class="product-card ratio-portrait">
                <div class="product-card__media">
                  <img src="{{ 'placeholder-product-' | append: i | append: '.svg' | asset_url }}" alt="" class="product-card__image product-card__placeholder" loading="lazy" width="600" height="800">
                </div>
                <div class="product-card__info"><h3 class="product-card__title">Producto {{ i }}</h3></div>
              </article>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      {%- if section.settings.layout == 'carousel' and section.settings.show_nav -%}
        <button type="button" class="product-carousel__btn product-carousel__btn--prev" data-carousel-prev aria-label="Anterior">‹</button>
        <button type="button" class="product-carousel__btn product-carousel__btn--next" data-carousel-next aria-label="Siguiente">›</button>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Carrusel de productos",
  "tag": "section",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Productos destacados" },
    { "type": "text", "id": "subheading", "label": "Subtítulo" },
    { "type": "collection", "id": "collection", "label": "Colección" },
    { "type": "product_list", "id": "product_list", "label": "Productos manuales (si no hay colección)" },
    { "type": "range", "id": "products_to_show", "min": 2, "max": 16, "step": 1, "label": "Cantidad", "default": 5 },
    {
      "type": "select",
      "id": "layout",
      "label": "Disposición",
      "options": [
        { "value": "carousel", "label": "Carrusel horizontal (Sunny)" },
        { "value": "grid", "label": "Grid" }
      ],
      "default": "carousel"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columnas (solo grid)",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" },
        { "value": "5", "label": "5" }
      ],
      "default": "4"
    },
    { "type": "checkbox", "id": "show_nav", "label": "Flechas navegación", "default": true },
    { "type": "checkbox", "id": "show_view_all", "label": "Enlace ver todo", "default": false }
  ],
  "presets": [
    {
      "name": "Carrusel de productos",
      "settings": {
        "heading": "El match perfecto para tu rutina",
        "layout": "carousel",
        "products_to_show": 5
      }
    }
  ]
}
{% endschema %}
