<section class="shop-look section-spacing">
  <div class="page-width shop-look__grid">
    <div class="shop-look__scene">
      {%- if section.settings.image != blank -%}
        {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', class: 'shop-look__img' }}
      {%- else -%}
        {% render 'section-placeholder', placeholder_type: 'lookbook', class: 'shop-look__img section-placeholder', width: 1200, height: 1400, alt: section.settings.heading %}
      {%- endif -%}
      {%- for block in section.blocks -%}
        {%- if block.settings.product != blank -%}
          <a href="{{ block.settings.product.url }}" class="lookbook__hotspot" style="top:{{ block.settings.y }}%;left:{{ block.settings.x }}%" {{ block.shopify_attributes }}>
            <span class="lookbook__dot"></span>
          </a>
        {%- endif -%}
      {%- endfor -%}
    </div>
    <div class="shop-look__products">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      <ul>
        {%- for block in section.blocks -%}
          {%- assign p = block.settings.product -%}
          {%- if p != blank -%}
            <li>
              <a href="{{ p.url }}">{{ p.featured_image | image_url: width: 80 | image_tag }}</a>
              <div>
                <a href="{{ p.url }}">{{ p.title }}</a>
                <span>{{ p.price | money }}</span>
              </div>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shop the look",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Imagen escena" },
    { "type": "text", "id": "heading", "label": "Título", "default": "Completa el look" }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Producto",
      "settings": [
        { "type": "product", "id": "product", "label": "Producto" },
        { "type": "range", "id": "x", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Posición X", "default": 30 },
        { "type": "range", "id": "y", "min": 0, "max": 100, "step": 1, "unit": "%", "label": "Posición Y", "default": 40 }
      ]
    }
  ],
  "presets": [{ "name": "Shop the look", "blocks": [{ "type": "product" }, { "type": "product" }] }]
}
{% endschema %}
