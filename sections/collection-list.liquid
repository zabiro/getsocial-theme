<section class="collection-list section-spacing">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <div class="section-header-row">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {%- endif -%}
    <div class="collection-list__grid collection-list__grid--{{ section.settings.columns }}">
      {%- for block in section.blocks -%}
        {%- assign coll = block.settings.collection -%}
        <a href="{{ coll.url | default: '#' }}" class="collection-list__card collection-list__card--{{ section.settings.card_style }}" {{ block.shopify_attributes }}>
          <div class="collection-list__media">
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- elsif coll.featured_image -%}
              {{ coll.featured_image | image_url: width: 600 | image_tag: loading: 'lazy' }}
            {%- else -%}
              {% render 'section-placeholder',
                placeholder_type: 'collection',
                placeholder_index: forloop.index,
                class: 'collection-list__img section-placeholder',
                width: 600,
                height: 750,
                alt: block.settings.title
              %}
            {%- endif -%}
            <div class="collection-list__overlay"></div>
          </div>
          <h3>{{ block.settings.title | default: coll.title | default: 'Colección' }}</h3>
          {%- if block.settings.button_label != blank -%}
            <span class="collection-list__btn">{{ block.settings.button_label }}</span>
          {%- endif -%}
        </a>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lista de colecciones",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Comprar por categoría" },
    { "type": "select", "id": "columns", "label": "Columnas", "options": [
      { "value": "2", "label": "2" },
      { "value": "3", "label": "3" },
      { "value": "4", "label": "4" }
    ], "default": "3" },
    { "type": "select", "id": "card_style", "label": "Estilo tarjeta", "options": [
      { "value": "overlay", "label": "Texto sobre imagen" },
      { "value": "below", "label": "Texto debajo" }
    ], "default": "overlay" }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Colección",
      "settings": [
        { "type": "collection", "id": "collection", "label": "Colección" },
        { "type": "image_picker", "id": "image", "label": "Imagen personalizada" },
        { "type": "text", "id": "title", "label": "Título personalizado" },
        { "type": "text", "id": "button_label", "label": "Texto botón", "default": "Ver colección" }
      ]
    }
  ],
  "presets": [{ "name": "Lista de colecciones", "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }] }]
}
{% endschema %}
