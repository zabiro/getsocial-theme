<section class="video-banner section-spacing">
  <div class="video-banner__wrap" style="min-height:{{ section.settings.height }}vh">
    {%- if section.settings.video != blank -%}
      {{ section.settings.video | video_tag: autoplay: true, loop: true, muted: true, playsinline: true, class: 'video-banner__video' }}
    {%- elsif section.settings.video_url != blank -%}
      <iframe src="{{ section.settings.video_url }}" title="{{ section.settings.heading }}" allowfullscreen loading="lazy"></iframe>
    {%- elsif section.settings.cover_image != blank -%}
      {{ section.settings.cover_image | image_url: width: 2000 | image_tag: class: 'video-banner__cover' }}
    {%- else -%}
      {% render 'section-placeholder', placeholder_type: 'video', class: 'video-banner__cover section-placeholder', width: 2000, height: 900, alt: section.settings.heading %}
    {%- endif -%}
    <div class="video-banner__overlay" style="opacity:{{ section.settings.overlay_opacity | divided_by: 100.0 }}"></div>
    <div class="page-width video-banner__content video-banner__content--{{ section.settings.alignment }}">
      {%- if section.settings.heading != blank -%}<h2>{{ section.settings.heading }}</h2>{%- endif -%}
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="button">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Banner de video",
  "settings": [
    { "type": "video", "id": "video", "label": "Video Shopify" },
    { "type": "video_url", "id": "video_url", "label": "URL YouTube/Vimeo", "accept": ["youtube", "vimeo"] },
    { "type": "image_picker", "id": "cover_image", "label": "Imagen de portada" },
    { "type": "range", "id": "height", "min": 40, "max": 100, "step": 5, "unit": "vh", "label": "Altura", "default": 60 },
    { "type": "range", "id": "overlay_opacity", "min": 0, "max": 80, "step": 5, "label": "Overlay %", "default": 30 },
    { "type": "text", "id": "heading", "label": "Título" },
    { "type": "text", "id": "button_label", "label": "Botón" },
    { "type": "url", "id": "button_link", "label": "Enlace" },
    { "type": "select", "id": "alignment", "label": "Alineación", "options": [
      { "value": "left", "label": "Izquierda" },
      { "value": "center", "label": "Centro" }
    ], "default": "center" }
  ],
  "presets": [{ "name": "Banner de video" }]
}
{% endschema %}
