<section class="slideshow section-spacing" data-slideshow style="min-height:{{ section.settings.height }}vh">
  {%- for block in section.blocks -%}
    <div class="slideshow__slide{% if forloop.first %} is-active{% endif %}" data-slide {{ block.shopify_attributes }}>
      {%- if block.settings.image != blank -%}
        {%- if forloop.first -%}
          {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'eager', sizes: '100vw' }}
        {%- else -%}
          {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', sizes: '100vw' }}
        {%- endif -%}
      {%- endif -%}
      <div class="page-width" style="position:absolute;bottom:20%;left:0;right:0;color:{{ block.settings.text_color }}">
        {%- if block.settings.heading != blank -%}<h2>{{ block.settings.heading }}</h2>{%- endif -%}
        {%- if block.settings.button_label != blank -%}
          <a href="{{ block.settings.link }}" class="button">{{ block.settings.button_label }}</a>
        {%- endif -%}
      </div>
    </div>
  {%- endfor -%}
  {%- if section.blocks.size > 1 -%}
    <div class="slideshow__nav">
      {%- for block in section.blocks -%}
        <button type="button" class="slideshow__dot{% if forloop.first %} is-active{% endif %}" data-slide-dot aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Slideshow",
  "max_blocks": 8,
  "settings": [
    { "type": "range", "id": "height", "min": 40, "max": 90, "step": 5, "unit": "vh", "label": "Altura", "default": 70 },
    { "type": "checkbox", "id": "autoplay", "label": "Autoplay", "default": true }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Diapositiva",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "heading", "label": "Título" },
        { "type": "text", "id": "button_label", "label": "Texto botón" },
        { "type": "url", "id": "link", "label": "Enlace" },
        { "type": "color", "id": "text_color", "label": "Color texto", "default": "#ffffff" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Slideshow",
      "blocks": [{ "type": "slide" }, { "type": "slide" }]
    }
  ]
}
{% endschema %}
