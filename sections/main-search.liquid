<section class="main-search section-spacing">
  <div class="page-width">
    <h1>{{ 'general.search' | t }}</h1>
    <form action="{{ routes.search_url }}" method="get" role="search" style="margin:1.5rem 0">
      <input type="search" name="q" value="{{ search.terms | escape }}" placeholder="{{ 'general.search' | t }}…">
      <button type="submit" class="button">{{ 'general.search' | t }}</button>
    </form>
    {%- if search.performed -%}
      <p>{{ search.results_count }} resultados</p>
      <div class="grid grid--4">
        {%- for item in search.results -%}
          {%- if item.object_type == 'product' -%}
            {% render 'product-card', product: item %}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Búsqueda",
  "class": "section-main-search"
}
{% endschema %}
