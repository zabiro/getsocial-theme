<section class="logo-list section-spacing">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}<h2 style="text-align:center;font-size:var(--font-size-h3);opacity:.7">{{ section.settings.heading }}</h2>{%- endif -%}
    <div class="logo-list__track{% if section.settings.enable_scroll %} logo-list__track--scroll{% endif %}" data-logo-marquee>
      {%- for block in section.blocks -%}
        <div class="logo-list__item" {{ block.shopify_attributes }}>
          {%- if block.settings.link != blank -%}<a href="{{ block.settings.link }}">{%- endif -%}
          {%- if block.settings.image != blank -%}
            {{ block.settings.image | image_url: width: 200 | image_tag: loading: 'lazy', alt: block.settings.title }}
          {%- else -%}
            <span>{{ block.settings.title }}</span>
          {%- endif -%}
          {%- if block.settings.link != blank -%}</a>{%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lista de logos",
  "settings": [
    { "type": "text", "id": "heading", "label": "Título", "default": "Marcas que confían en nosotros" },
    { "type": "checkbox", "id": "enable_scroll", "label": "Scroll infinito", "default": true }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Imagen" },
        { "type": "text", "id": "title", "label": "Nombre (si no hay imagen)" },
        { "type": "url", "id": "link", "label": "Enlace" }
      ]
    }
  ],
  "presets": [{ "name": "Lista de logos", "blocks": [{ "type": "logo" }, { "type": "logo" }, { "type": "logo" }, { "type": "logo" }] }]
}
{% endschema %}
